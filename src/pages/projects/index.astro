---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const projects = (await getCollection('projects')).sort((a, b) => {
	const aImportance = Number(a.data.importance ?? 0);
	const bImportance = Number(b.data.importance ?? 0);

	if (aImportance !== bImportance) {
		return bImportance - aImportance;
	}

	const aDate = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
	const bDate = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;

	return bDate - aDate;
});

const categories = [
	"all",
	"current",
	"resources",
	"outdated",
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}

			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}

			ul li {
				width: calc(50% - 1rem);
			}

			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}

			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}

			ul li:first-child img {
				width: 100%;
			}

			ul li:first-child .title {
				font-size: 2.369rem;
			}

			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}

			ul li a {
				display: block;
			}

			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}

			.date {
				margin: 0;
				color: rgb(var(--gray));
			}

			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}

			ul a:hover img {
				box-shadow: var(--box-shadow);
			}

			.selector {
				display: flex;
				gap: 1rem;
				margin-bottom: 1rem;
			}

			.filter-btn.active {
				color: rgb(var(--accent));
				font-weight: bold;
			}

			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}

				ul li {
					width: 100%;
					text-align: center;
				}

				ul li:first-child {
					margin-bottom: 0;
				}

				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<section>

				<div class="selector">
					{
						categories.map(category => (
							<button
								class="filter-btn"
								data-category={category}
							>
								{category}
							</button>
						))
					}
				</div>

				<ul>
					{
						projects.map((project) => {
							const now = new Date();
							now.setHours(0, 0, 0, 0);

							const rawDate = project.data.pubDate;
							const pubDate = rawDate ? new Date(rawDate) : null;

							let diffDays: number | null = null;
							let isFuture = false;

							if (pubDate && !isNaN(pubDate.getTime())) {
								pubDate.setHours(0, 0, 0, 0);

								diffDays = Math.floor(
									(now.getTime() - pubDate.getTime()) / (1000 * 60 * 60 * 24)
								);

								isFuture = diffDays < 0;
								diffDays = Math.abs(diffDays);
							}

							const endDate = project.data.endDate
								? new Date(project.data.endDate)
								: null;

							let daysTo: number | null = null;

							if (endDate && !isNaN(endDate.getTime())) {
								daysTo = Math.ceil(
									(endDate.getTime() - Date.now()) / 86400000
								);
							}

							return (
								<li data-category={String(project.data.category ?? "").trim().toLowerCase()}>
									<a href={`/projects/${project.id}/`}>
										{project.data.heroImage && (
											<Image
												width={1440}
												height={720}
												src={project.data.heroImage}
												alt=""
											/>
										)}

										<h4 class="title">{project.data.title}</h4>

										<p class="date">
											<span>
												{diffDays === null
													? ""
													: isFuture
														? diffDays === 0
															? "Starts today"
															: `Starts in ${diffDays} day${diffDays === 1 ? "" : "s"}`
														: diffDays === 0
															? "Starts today"
															: `Started ${diffDays} day${diffDays === 1 ? "" : "s"} ago`}

												{daysTo !== null && (
													<>
														{" • "}
														{daysTo} day{daysTo === 1 ? "" : "s"} left
													</>
												)}
											</span>
										</p>
									</a>
								</li>
							);
						})
					}
				</ul>

			</section>
		</main>

		<script>
			document.addEventListener("DOMContentLoaded", () => {
				const buttons = document.querySelectorAll(".filter-btn");
				const projects = document.querySelectorAll("ul li");

				buttons.forEach(btn => {
					btn.addEventListener("click", () => {

						const selected = (btn.dataset.category || "").trim().toLowerCase();

						buttons.forEach(b => b.classList.remove("active"));
						btn.classList.add("active");

						projects.forEach(p => {
							const cat = (p.dataset.category || "").trim().toLowerCase();

							const show =
								selected === "all" ||
								cat === selected;

							p.style.display = show ? "" : "none";
						});
					});
				});
			});
		</script>

		<Footer />
	</body>
</html>